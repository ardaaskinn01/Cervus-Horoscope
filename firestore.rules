rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Kullanıcı bilgileri: Sadece giriş yapmış kullanıcı kendi dokümanını okuyabilir ve yazabilir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Kullanıcının alt koleksiyonları (natal_chart, compatibility, character_analysis, best_matches)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Günlük yorumlar: Herkes okuyabilir ve yazabilir (oturum açılmamış olsa bile)
    match /daily_comments/{commentId} {
      allow read, write: if true;
    }

    // Aylık yorumlar: Herkes okuyabilir ve yazabilir (oturum açılmamış olsa bile)
    match /monthly_comments/{commentId} {
      allow read, write: if true;
    }

    // Cihaz bazlı limitler: Giriş yapmış tüm kullanıcılar erişebilir
    match /device_limits/{deviceId} {
      allow read, write: if request.auth != null;
    }

    // Genel uygulama ayarları
    match /settings/{settingId} {
      allow read: if true;
    }
  }
}

